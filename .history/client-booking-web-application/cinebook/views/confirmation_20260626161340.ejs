


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Booking Confirmed — CineBook</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
<a id="top"></a>

<!-- NAVBAR (with BACK arrow) -->
<nav class="site-nav">
  <div class="nav-inner">
    <div class="nav-left">
      <a href="/" class="back-btn"><span class="back-arrow">&larr;</span> Back to films</a>
      <span class="nav-divider"></span>
      <a href="/" class="logo">
        <span class="logo-mark"></span>
        <span class="logo-text"><span class="logo-cine">CINE</span><span class="logo-book">BOOK</span></span>
      </a>
    </div>
    <span class="nav-wordmark">CINEMA BOOKING</span>
  </div>
</nav>

<main class="page">
  <section class="confirm">
    <div class="confirm-check">&checkmark;</div>
    <h1 class="confirm-title">Booking Confirmed</h1>
    <p class="confirm-sub">Your tickets are ready. A copy would be emailed to you.</p>

    <% const ref = 'CIN-' + Math.floor(1000 + Math.random() * 9000); %>
    <% const seatList = Array.isArray(seats) ? seats.join(', ') : seats; %>

    <div class="ticket">
      <div class="ticket-head">
        <span><span class="logo-cine">CINE</span>BOOK &middot; ADMIT ONE</span>
        <span class="logo-mark"></span>
      </div>
      <div class="ticket-body">
        <div class="ticket-row"><span>Seats</span><b><%= seatList || '—' %></b></div>
        <div class="ticket-row"><span>Tickets</span><b><%= Array.isArray(seats) ? seats.length : (seats ? 1 : 0) %></b></div>
        <div class="ticket-row"><span>Total</span><b><%= total %></b></div>
        <div class="ticket-perf"></div>
        <div class="ticket-ref">
          <div>
            <span class="info-label">Booking reference</span>
            <span class="ticket-code"><%= ref %></span>
          </div>
          <span class="ticket-keep">Keep this safe</span>
        </div>
      </div>
    </div>

    <a href="/" class="btn-cine btn-outline" style="margin-top:1.6rem;">Back to films</a>
  </section>
</main>

<!-- FOOTER -->
<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <span class="logo-text"><span class="logo-cine">CINE</span><span class="logo-book">BOOK</span></span>
      <p class="footer-tag">Book your seat in seconds.</p>
    </div>
    <nav class="footer-links">
      <a href="/">Now Showing</a>
      <a href="#top">Back to top</a>
    </nav>
    <p class="footer-credit">&copy; 2026 CineBook &middot; Placement group project</p>
  </div>
</footer>
</body>
</html>