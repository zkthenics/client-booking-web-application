

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Choose Seats — CineBook</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
<a id="top"></a>

<!-- NAVBAR (with BACK arrow) -->
<nav class="site-nav">
  <div class="nav-inner">
    <div class="nav-left">
      <a href="/" class="back-btn"><span class="back-arrow">&larr;</span> Back to films</a>
      <span class="nav-divider"></span>
      <a href="/" class="logo">
        <span class="logo-mark"></span>
        <span class="logo-text"><span class="logo-cine">CINE</span><span class="logo-book">BOOK</span></span>
      </a>
    </div>
    <span class="nav-wordmark">CINEMA BOOKING</span>
  </div>
</nav>

<main class="seat-page">
  <div class="seat-head">
    <h1>Select Your Seats</h1>
    <p class="seat-screen-info"><%= showing.type %> &middot; <%= showing.screenName %></p>
  </div>

  <div class="screen">SCREEN</div>
  <div class="screen-label">Screen</div>

  <form action="/confirmation" method="GET" id="seatForm">
    <% showing.rows.forEach(row => { %>
      <div class="seat-row">
        <span class="row-label"><%= row.name %></span>
        <% row.seats.forEach(seat => { %>
          <% if (seat.available) { %>
            <input type="checkbox" id="<%= row.name %><%= seat.number %>" name="seats" value="<%= row.name %><%= seat.number %>" />
            <label for="<%= row.name %><%= seat.number %>" class="seat available"><%= seat.number %></label>
          <% } else { %>
            <span class="seat unavailable">&times;</span>
          <% } %>
        <% }) %>
      </div>
    <% }) %>

    <div class="legend">
      <div><span class="seat available"></span> <span>Available</span></div>
      <div><span class="seat selected-demo"></span> <span>Selected</span></div>
      <div><span class="seat unavailable"></span> <span>Unavailable</span></div>
    </div>

    <div class="selection-bar">
      <div class="sel-left">
        <div class="sel-label">Seats selected</div>
        <div class="sel-count" id="seatCount">0 / 6</div>
        <div class="sel-total">Total: <b id="seatTotal">&pound;0.00</b></div>
      </div>
      <input type="hidden" name="total" id="totalField" value="&pound;0.00" />
      <button type="submit" class="btn-cine" id="continueBtn" disabled>Continue to checkout</button>
    </div>
  </form>
</main>

<!-- FOOTER -->
<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <span class="logo-text"><span class="logo-cine">CINE</span><span class="logo-book">BOOK</span></span>
      <p class="footer-tag">Book your seat in seconds.</p>
    </div>
    <nav class="footer-links">
      <a href="/">Now Showing</a>
      <a href="#top">Back to top</a>
    </nav>
    <p class="footer-credit">&copy; 2026 CineBook &middot; Placement group project</p>
  </div>
</footer>

<script src="/seats.js"></script>
</body>
</html>