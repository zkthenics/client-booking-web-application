<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cinema Booking System</title>

    <link rel="stylesheet" href="/styles.css">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body{
            background:#111;
            color:white;
        }

        .hero{
            background:url("https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=1600") center/cover;
            height:320px;
            display:flex;
            justify-content:center;
            align-items:center;
            text-align:center;
            margin-bottom:50px;
        }

        .hero h1{
            font-size:4rem;
            font-weight:bold;
            text-shadow:3px 3px 8px black;
        }

        .movie-card{
            transition:.3s;
            border:none;
            border-radius:20px;
            overflow:hidden;
            background:#1d1d1d;
        }

        .movie-card:hover{
            transform:translateY(-10px);
            box-shadow:0 0 25px rgba(255,255,255,.25);
        }

        .movie-card img{
            height:450px;
            object-fit:cover;
            cursor:pointer;
        }

        .card-body{
            color:white;
        }

        .btn-book{
            background:#dc3545;
            color:white;
        }

        .btn-book:hover{
            background:#bb2d3b;
            color:white;
        }

        .modal-content{
            background:#202020;
            color:white;
        }

        .modal-header{
            border-bottom:1px solid #444;
        }

        .modal-footer{
            border-top:1px solid #444;
        }

        .show-btn{
            width:130px;
        }

    </style>

</head>

<body>

<div class="hero">

    <div>

        <h1>Cinema Booking</h1>

        <h4>Choose your movie and reserve your seats</h4>

    </div>

</div>

<div class="container">

    <div class="row g-4">

        <% movies.forEach(movie => { %>

            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="card movie-card h-100">

                    <img
                        src="<%= movie.poster %>"
                        alt="<%= movie.title %>"
                        data-bs-toggle="modal"
                        data-bs-target="#movie<%= movie.id %>"
                    >

                    <div class="card-body">

                        <h4><%= movie.title %></h4>

                        <p>
                            <strong><%= movie.rating %></strong>
                            •
                            <%= movie.genre %>
                        </p>

                        <p><%= movie.duration %> mins</p>

                        <button
                            class="btn btn-book w-100"
                            data-bs-toggle="modal"
                            data-bs-target="#movie<%= movie.id %>">

                            View Showings

                        </button>

                    </div>

                </div>

            </div>

            <!-- Modal -->

            <div class="modal fade" id="movie<%= movie.id %>" tabindex="-1">

                <div class="modal-dialog modal-lg modal-dialog-centered">

                    <div class="modal-content">

                        <div class="modal-header">

                            <h2><%= movie.title %></h2>

                            <button
                                class="btn-close btn-close-white"
                                data-bs-dismiss="modal">
                            </button>

                        </div>

                        <div class="modal-body">

                            <div class="row">

                                <div class="col-md-5">

                                    <img
                                        src="<%= movie.poster %>"
                                        class="img-fluid rounded">

                                </div>

                                <div class="col-md-7">

                                    <h5>Movie Information</h5>

                                    <p><strong>Rating:</strong> <%= movie.rating %></p>

                                    <p><strong>Genre:</strong> <%= movie.genre %></p>

                                    <p><strong>Duration:</strong> <%= movie.duration %> mins</p>

                                    <p><%= movie.description %></p>

                                    <hr>

                                    <h4>Select a Showing</h4>

                                    <div class="d-flex flex-wrap gap-2">

                                        <% movie.showtimes.forEach(show => { %>

                                            <a
                                                href="/seats?showingId=<%= show.showingId %>"
                                                class="btn btn-danger show-btn">

                                                <%= show.date %>

                                                <br>

                                                <%= show.time %>

                                            </a>

                                        <% }) %>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>